{
  "$comment": "please-work-claude 강제 층(§9 금지 + §7 boost + §6 antithesis) 템플릿. setup이 이 hooks 블록을 사용자 ~/.claude/settings.json(또는 프로젝트 .claude/settings.json)에 병합하고 command 경로의 ${CLAUDE_PROJECT_DIR}를 실제 설치 경로로 치환한다. PreToolUse는 exit 2로 도구를 하드 차단, Stop은 decision:block으로 antithesis 미실행 시 턴 종료를 1회 막아 환기한다.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-secrets.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/guard-git.sh" }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/mark-work.sh" }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/session-start-boost.sh" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/stop-antithesis.sh" }
        ]
      }
    ]
  }
}
